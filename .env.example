# Twitch API Credentials
MAIN_VITE_TWITCH_CLIENT_ID=
MAIN_VITE_TWITCH_CLIENT_SECRET=

# YouTube API Credentials (Google Cloud Console)
MAIN_VITE_YOUTUBE_API_KEY=
MAIN_VITE_YOUTUBE_CLIENT_ID=
MAIN_VITE_YOUTUBE_CLIENT_SECRET=

# Kick API Credentials (Official Developer Portal)
MAIN_VITE_KICK_CLIENT_ID=
MAIN_VITE_KICK_CLIENT_SECRET=

# ----------------------------------------------------------------
# YouTube ChatPopup — Tuning Opcional
# O provider (official_api | chat_popup) é selecionado pela UI.
# As variáveis abaixo são opcionais e possuem valores padrão no código.
# ----------------------------------------------------------------
# MAIN_VITE_YOUTUBE_CHATPOPUP_POLL_MIN_MS=1500
# MAIN_VITE_YOUTUBE_CHATPOPUP_POLL_MAX_MS=8000
# MAIN_VITE_YOUTUBE_CHATPOPUP_INITIAL_TIMEOUT_MS=12000
# MAIN_VITE_YOUTUBE_CHATPOPUP_MAX_RETRIES=5
# MAIN_VITE_YOUTUBE_CHATPOPUP_FILTER_MODE=live_all

# ----------------------------------------------------------------
# YouTube Official API Polling — Tuning Opcional
# As variáveis abaixo são opcionais e possuem valores padrão no código.
# Valores numéricos (tempo em segundos para os min/max/steps e inteiro para threshold)
# ----------------------------------------------------------------
# MAIN_VITE_YOUTUBE_POLL_INTERVAL_MIN=8
# MAIN_VITE_YOUTUBE_POLL_INTERVAL_MAX=20
# MAIN_VITE_YOUTUBE_POLL_EMPTY_THRESHOLD=4
# MAIN_VITE_YOUTUBE_POLL_INCREMENT_STEP=2
# MAIN_VITE_YOUTUBE_POLL_DECREMENT_STEP=2
